import os
from dotenv import load_dotenv

load_dotenv()

# Database
DATABASE_URL=sqlite+aiosqlite:///./testzoo.db

# JWT & Security
SECRET_KEY=your-super-secret-key-change-in-production-12345
ALGORITHM=HS256

# SMTP Configuration for OTP Emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@testzoo.com

# WhatsApp Configuration (Twilio Example)
WHATSAPP_API_URL=https://api.twilio.com/2010-04-01/Accounts
WHATSAPP_API_TOKEN=your-twilio-auth-token
WHATSAPP_PHONE_NUMBER=+1234567890
TWILIO_ACCOUNT_SID=your-twilio-account-sid

# Stripe Payment
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Payment Settings
CASHBACK_PERCENT=5

# URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Razorpay (Alternative Payment)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
